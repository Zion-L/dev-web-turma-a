{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuSalgados: []\n    };\n  },\n  methods: {\n    async consultarMenu() {\n      const response = await fetch(\"http://localhost:3000/menu\");\n      const dados = await response.json();\n      this.listaMenuSalgados = dados.salgados;\n      console.log(this.listaMenuSalgados);\n    },\n    selecionarSalgado(salgadoSelecionado) {\n      const param = JSON.stringify(salgadoSelecionado);\n      const salgadoJson = encodeURIComponent(param);\n      this.$router.push({\n        path: \"/config\",\n        query: {\n          salgado: salgadoJson\n        }\n      });\n    }\n  },\n  mounted() {\n    this.consultarMenu();\n  }\n};","map":{"version":3,"names":["name","data","listaMenuSalgados","methods","consultarMenu","response","fetch","dados","json","salgados","console","log","selecionarSalgado","salgadoSelecionado","param","JSON","stringify","salgadoJson","encodeURIComponent","$router","push","path","query","salgado","mounted"],"sources":["c:\\Users\\patcr\\OneDrive\\Área de Trabalho\\CEUB VICTOR\\dev-web-turma-a\\Victor Prata\\Projeto Final\\projetofinal\\src\\views\\MenuView.vue"],"sourcesContent":["<template>\n  <div>\n    <h1>Menu</h1>\n    <div id=\"scroll-horizontal\">\n      <div\n        id=\"card-content\"\n        v-for=\"salgado in listaMenuSalgados\"\n        :key=\"salgado.id\"\n      >\n        <div id=\"card-linha\">\n          <div class=\"foto-hamburguer\">\n            <img :src=\"salgado.foto\" alt=\"nome do salgado\" />\n            <div class=\"card-coluna\">\n              <p id=\"nome-content\">{{ salgado.nome }}</p>\n              <p id=\"preco-content\">R$ {{ salgado.valor }},00</p>\n              <p id=\"descricao-content\">{{ salgado.descricao }}</p>\n              <button @click=\"selecionarSalgado(salgado)\">Selecionar</button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n<script>\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuSalgados: [],\n    };\n  },\n  methods: {\n    async consultarMenu() {\n      const response = await fetch(\"http://localhost:3000/menu\");\n      const dados = await response.json();\n      this.listaMenuSalgados = dados.salgados;\n      console.log(this.listaMenuSalgados);\n    },\n    selecionarSalgado(salgadoSelecionado) {\n      const param = JSON.stringify(salgadoSelecionado);\n      const salgadoJson = encodeURIComponent(param);\n      this.$router.push({ path: \"/config\", query: { salgado: salgadoJson } });\n    },\n  },\n  mounted() {\n    this.consultarMenu();\n  },\n};\n</script>\n<style scoped>\n#card-content {\n  display: inline-block;\n  width: 280px;\n  min-height: 500px;\n  margin: 20px;\n  border: 1px solid #ddd;\n  border-radius: 15px;\n  box-shadow: 0 4px 8px #444;\n  position: relative;\n  overflow: hidden;\n}\n\n#scroll-horizontal {\n  flex: 1;\n  overflow-x: auto;\n  white-space: nowrap;\n  width: 700px;\n  margin: 0 auto;\n  box-shadow: inset -10px 0px 15px -15px grey;\n}\n\n.foto-hamburguer img {\n  width: 100%;\n  object-fit: cover;\n  max-height: 200px;\n  border-radius: 10px 0 0;\n}\n\n#nome-content {\n  font-size: 25px;\n  font-weight: bold;\n  text-align: center;\n  width: 100%;\n  margin: 12px;\n}\n\n#preco-content {\n  font-size: 35px;\n  text-align: center;\n  font-weight: bold;\n  color: green;\n  margin: 16px;\n}\n\n#descricao-content {\n  font-size: 16px;\n  text-align: left;\n  color: gray;\n  margin: 16px;\n  white-space: pre-line;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  display: -webkit-box;\n  -webkit-line-clamp: 6;\n  -webkit-box-orient: vertical;\n}\n\n.card-coluna button {\n  margin-top: auto;\n  padding: 10px;\n  background-color: rgb(53, 108, 121);\n  color: #fff;\n  font-weight: bold;\n  border-radius: 8px;\n  border: none;\n  font-size: 14px;\n  width: 80%;\n  margin: 20px;\n  cursor: pointer;\n  transition: 0.5s;\n}\n\n.card-coluna button:hover {\n  background-color: transparent;\n  color: darkslategray;\n  border-radius: 8px;\n  border: solid 1px rgb(53, 108, 121);\n}\n</style>\n"],"mappings":";AAyBA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,iBAAiB,EAAE;IACrB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,aAAaA,CAAA,EAAG;MACpB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,4BAA4B,CAAC;MAC1D,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACN,iBAAgB,GAAIK,KAAK,CAACE,QAAQ;MACvCC,OAAO,CAACC,GAAG,CAAC,IAAI,CAACT,iBAAiB,CAAC;IACrC,CAAC;IACDU,iBAAiBA,CAACC,kBAAkB,EAAE;MACpC,MAAMC,KAAI,GAAIC,IAAI,CAACC,SAAS,CAACH,kBAAkB,CAAC;MAChD,MAAMI,WAAU,GAAIC,kBAAkB,CAACJ,KAAK,CAAC;MAC7C,IAAI,CAACK,OAAO,CAACC,IAAI,CAAC;QAAEC,IAAI,EAAE,SAAS;QAAEC,KAAK,EAAE;UAAEC,OAAO,EAAEN;QAAY;MAAE,CAAC,CAAC;IACzE;EACF,CAAC;EACDO,OAAOA,CAAA,EAAG;IACR,IAAI,CAACpB,aAAa,CAAC,CAAC;EACtB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}