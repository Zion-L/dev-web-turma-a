{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nexport default {\n  name: \"PedidosView\",\n  data() {\n    return {\n      listaPedidos: [],\n      msg: null\n    };\n  },\n  methods: {\n    async consultarPedidos() {\n      const response = await fetch(\"http://localhost:3000/pedidos\");\n      const dados = await response.json();\n      this.listaPedidos = dados;\n    },\n    async deletarPedido(id) {\n      const response = await fetch(`http://localhost:3000/pedidos/${id}`, {\n        method: \"DELETE\"\n      });\n      if (response.ok) {\n        this.listaPedidos = this.listaPedidos.filter(p => p.id !== id);\n        this.msg = {\n          texto: \"Pedido excluído com sucesso!\",\n          tipo: \"sucesso\"\n        };\n        setTimeout(() => {\n          this.msg = null;\n        }, 2000);\n      } else {\n        this.msg = {\n          texto: \"Erro ao excluir o pedido.\",\n          tipo: \"erro\"\n        };\n      }\n    }\n  },\n  mounted() {\n    this.consultarPedidos();\n  }\n};","map":{"version":3,"names":["name","data","listaPedidos","msg","methods","consultarPedidos","response","fetch","dados","json","deletarPedido","id","method","ok","filter","p","texto","tipo","setTimeout","mounted"],"sources":["c:\\Users\\patcr\\OneDrive\\Área de Trabalho\\CEUB VICTOR\\dev-web-turma-a\\Victor Prata\\Projeto Final\\projetofinal\\src\\views\\PedidosView.vue"],"sourcesContent":["<template>\n  <div>\n    <h1>Pedidos</h1>\n    <div v-if=\"msg\" :class=\"['alerta', msg.tipo]\">\n      <span class=\"alerta-icone\">{{ iconeAlerta(msg.tipo) }}</span>\n      {{ msg.texto }}\n    </div>\n    <div id=\"pedidos-container\">\n      <div\n        id=\"pedido-card\"\n        v-for=\"pedido in listaPedidos\"\n        :key=\"pedido.id\"\n      >\n        <div id=\"pedido-header\">\n          <p id=\"pedido-nome\">{{ pedido.nome }}</p>\n          <img\n            id=\"icone-lixeira\"\n            src=\"/img/icone_lixeira.png\"\n            @click=\"deletarPedido(pedido.id)\"\n            title=\"Excluir pedido\"\n          />\n        </div>\n        <div id=\"pedido-salgado\">\n          <img :src=\"pedido.salgado && pedido.salgado.foto ? pedido.salgado.foto : ''\" id=\"foto-salgado\" />\n          <p id=\"nome-salgado\">{{ pedido.salgado && pedido.salgado.nome ? pedido.salgado.nome : '-' }}</p>\n        </div>\n        <div id=\"pedido-detalhes\">\n          <div v-if=\"pedido.complementos && pedido.complementos.length\">\n            <p class=\"detalhe-titulo\">Complementos:</p>\n            <span\n              class=\"detalhe-item\"\n              v-for=\"complemento in pedido.complementos\"\n              :key=\"complemento.id\"\n            >\n              {{ complemento.nome }}\n            </span>\n          </div>\n          <div v-if=\"pedido.bebidas && pedido.bebidas.length\">\n            <p class=\"detalhe-titulo\">Bebidas:</p>\n            <span\n              class=\"detalhe-item\"\n              v-for=\"bebida in pedido.bebidas\"\n              :key=\"bebida.id\"\n            >\n              {{ bebida.nome }}\n            </span>\n          </div>\n        </div>\n        <div id=\"pedido-status\">\n          <p>Status: <strong>{{ pedido.statusId }}</strong></p>\n        </div>\n      </div>\n      <p v-if=\"listaPedidos.length === 0\" id=\"sem-pedidos\">Nenhum pedido realizado ainda.</p>\n    </div>\n  </div>\n</template>\n<script>\nexport default {\n  name: \"PedidosView\",\n  data() {\n    return {\n      listaPedidos: [],\n      msg: null,\n    };\n  },\n  methods: {\n    async consultarPedidos() {\n      const response = await fetch(\"http://localhost:3000/pedidos\");\n      const dados = await response.json();\n      this.listaPedidos = dados;\n    },\n    async deletarPedido(id) {\n      const response = await fetch(`http://localhost:3000/pedidos/${id}`, {\n        method: \"DELETE\",\n      });\n      if (response.ok) {\n        this.listaPedidos = this.listaPedidos.filter((p) => p.id !== id);\n        this.msg = { texto: \"Pedido excluído com sucesso!\", tipo: \"sucesso\" };\n        setTimeout(() => {\n          this.msg = null;\n        }, 2000);\n      } else {\n        this.msg = { texto: \"Erro ao excluir o pedido.\", tipo: \"erro\" };\n      }\n    },\n  },\n  mounted() {\n    this.consultarPedidos();\n  },\n};\n</script>\n<style scoped>\n#pedidos-container {\n  max-width: 750px;\n  margin: 0 auto;\n  padding: 16px;\n}\n\n#pedido-card {\n  border: 1px solid #ddd;\n  border-radius: 15px;\n  box-shadow: 0 4px 8px #444;\n  margin-bottom: 20px;\n  overflow: hidden;\n}\n\n#pedido-header {\n  background-color: #333;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 12px 20px;\n  border-bottom: 4px solid darkgoldenrod;\n}\n\n#pedido-nome {\n  font-size: 22px;\n  font-weight: bold;\n  color: darkgoldenrod;\n  margin: 0;\n}\n\n#icone-lixeira {\n  width: 28px;\n  height: 28px;\n  cursor: pointer;\n  transition: 0.2s;\n}\n\n#icone-lixeira:hover {\n  width: 32px;\n  height: 32px;\n}\n\n#pedido-salgado {\n  display: flex;\n  align-items: center;\n  padding: 12px 20px;\n  gap: 16px;\n  background-color: #f9f9f9;\n}\n\n#foto-salgado {\n  width: 80px;\n  height: 80px;\n  object-fit: cover;\n  border-radius: 8px;\n}\n\n#nome-salgado {\n  font-size: 20px;\n  font-weight: bold;\n  color: #222;\n  margin: 0;\n}\n\n#pedido-detalhes {\n  padding: 12px 20px;\n}\n\n.detalhe-titulo {\n  font-weight: bold;\n  color: #222;\n  margin: 8px 0 4px;\n  border-left: 4px solid darkgoldenrod;\n  padding-left: 8px;\n}\n\n.detalhe-item {\n  display: inline-block;\n  background-color: #eee;\n  border-radius: 8px;\n  padding: 4px 10px;\n  margin: 4px;\n  font-size: 13px;\n  color: #333;\n}\n\n#pedido-status {\n  padding: 10px 20px;\n  background-color: #f0f0f0;\n  border-top: 1px solid #ddd;\n  text-align: right;\n  font-size: 14px;\n  color: #555;\n}\n\n#sem-pedidos {\n  text-align: center;\n  font-size: 18px;\n  color: gray;\n  margin-top: 40px;\n}\n\n.alerta {\n  padding: 12px 16px;\n  border-radius: 8px;\n  font-weight: bold;\n  margin: 16px auto;\n  text-align: center;\n  max-width: 750px;\n}\n\n.sucesso {\n  background-color: #28a745;\n  color: white;\n}\n\n.erro {\n  background-color: #dc3545;\n  color: white;\n}\n\n.aviso {\n  background-color: #fd7e14;\n  color: white;\n}\n\n.info {\n  background-color: #17a2b8;\n  color: white;\n}\n</style>\n"],"mappings":";;AAyDA,eAAe;EACbA,IAAI,EAAE,aAAa;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,YAAY,EAAE,EAAE;MAChBC,GAAG,EAAE;IACP,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,gBAAgBA,CAAA,EAAG;MACvB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,+BAA+B,CAAC;MAC7D,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACP,YAAW,GAAIM,KAAK;IAC3B,CAAC;IACD,MAAME,aAAaA,CAACC,EAAE,EAAE;MACtB,MAAML,QAAO,GAAI,MAAMC,KAAK,CAAC,iCAAiCI,EAAE,EAAE,EAAE;QAClEC,MAAM,EAAE;MACV,CAAC,CAAC;MACF,IAAIN,QAAQ,CAACO,EAAE,EAAE;QACf,IAAI,CAACX,YAAW,GAAI,IAAI,CAACA,YAAY,CAACY,MAAM,CAAEC,CAAC,IAAKA,CAAC,CAACJ,EAAC,KAAMA,EAAE,CAAC;QAChE,IAAI,CAACR,GAAE,GAAI;UAAEa,KAAK,EAAE,8BAA8B;UAAEC,IAAI,EAAE;QAAU,CAAC;QACrEC,UAAU,CAAC,MAAM;UACf,IAAI,CAACf,GAAE,GAAI,IAAI;QACjB,CAAC,EAAE,IAAI,CAAC;MACV,OAAO;QACL,IAAI,CAACA,GAAE,GAAI;UAAEa,KAAK,EAAE,2BAA2B;UAAEC,IAAI,EAAE;QAAO,CAAC;MACjE;IACF;EACF,CAAC;EACDE,OAAOA,CAAA,EAAG;IACR,IAAI,CAACd,gBAAgB,CAAC,CAAC;EACzB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}